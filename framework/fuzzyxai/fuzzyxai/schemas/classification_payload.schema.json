{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FuzzyXAI classification payload",
  "type": "object",
  "required": ["scenario_id", "source_type", "model_name", "dataset_name", "predicted_class", "class_probability", "feature_values", "feature_importance", "quality_metrics"],
  "properties": {
    "scenario_id": {"type": "string"},
    "source_type": {"type": "string"},
    "model_name": {"type": "string"},
    "dataset_name": {"type": "string"},
    "predicted_class": {"type": ["integer", "number", "string"]},
    "class_probability": {"type": "number", "minimum": 0, "maximum": 1},
    "feature_values": {"type": "object"},
    "feature_importance": {"type": "object"},
    "quality_metrics": {"type": "object"},
    "context_values": {"type": "object"}
  }
}
